{
  "$schema": "https://schema.tauri.app/config/1",
  "package": {
    "productName": "cpmsClient",
    "version": "0.1.8"
  },
  "build": {
    "beforeDevCommand": "pnpm dev:ui",
    "beforeBuildCommand": "pnpm build:ui",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "tauri": {
    "windows": [
      {
        "title": "cpmsClient",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    },
    "allowlist": {
      "all": true
    },
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    },
    "bundle": {
      "active": true,
      "targets": ["deb", "rpm"],
      "identifier": "com.cpms.client.legacy",
      "publisher": "CPMS",
      "category": "Business",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico",
        "icons/icon.png"
      ],
      "deb": {
        "depends": ["libwebkit2gtk-4.0-37", "libgtk-3-0", "libappindicator3-1 | libayatana-appindicator3-1"]
      }
    }
  }
}
