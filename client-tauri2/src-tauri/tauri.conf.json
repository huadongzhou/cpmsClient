{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cpmsClient",
  "version": "0.1.5",
  "identifier": "com.cpms.client",
  "build": {
    "beforeDevCommand": "pnpm --dir ../client-ui dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --dir ../client-ui build",
    "frontendDist": "../../client-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "cpmsClient",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb", "rpm", "appimage"],
    "publisher": "CPMS",
    "category": "Business",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libappindicator3-1"]
      }
    }
  }
}
