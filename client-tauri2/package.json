{
  "name": "cpms-client-tauri2",
  "version": "0.1.8",
  "private": true,
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "node scripts/build.js all",
    "build:win": "node scripts/build.js win",
    "build:win:msi": "node scripts/build.js msi",
    "build:win:nsis": "node scripts/build.js nsis",
    "build:win:x64": "tauri build --target x86_64-pc-windows-msvc --bundles msi nsis",
    "build:win:arm64": "tauri build --target aarch64-pc-windows-msvc --bundles msi nsis",
    "build:mac": "tauri build --bundles app dmg",
    "build:linux": "node scripts/build.js linux",
    "build:linux:deb": "node scripts/build.js deb",
    "build:linux:rpm": "node scripts/build.js rpm",
    "build:linux:appimage": "node scripts/build.js appimage",
    "build:linux:x64": "tauri build --config src-tauri/tauri.linux.conf.json --target x86_64-unknown-linux-gnu --bundles deb rpm",
    "build:linux:arm64": "tauri build --config src-tauri/tauri.linux.conf.json --target aarch64-unknown-linux-gnu --bundles deb rpm",
    "build:linux:deb:x64": "tauri build --config src-tauri/tauri.linux.conf.json --target x86_64-unknown-linux-gnu --bundles deb",
    "build:linux:deb:arm64": "tauri build --config src-tauri/tauri.linux.conf.json --target aarch64-unknown-linux-gnu --bundles deb",
    "build:all": "node scripts/build.js all"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}
